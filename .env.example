# ===========================================
# IPL Data Platform - Environment Configuration
# ===========================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ipl_analytics
POSTGRES_USER=ipl_admin
POSTGRES_PASSWORD=ipl_secure_password_2024

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_BALL_EVENTS=ipl.ball.events
KAFKA_TOPIC_MATCH_UPDATES=ipl.match.updates
KAFKA_TOPIC_PLAYER_EVENTS=ipl.player.events
KAFKA_CONSUMER_GROUP=ipl-analytics-group

# Spark
SPARK_MASTER=spark://spark-master:7077
SPARK_APP_NAME=IPLAnalyticsPlatform
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://ipl_admin:ipl_secure_password_2024@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-here

# Data Paths
DATA_LAKE_PATH=/opt/data/lake
DATA_WAREHOUSE_PATH=/opt/data/warehouse
RAW_DATA_PATH=/opt/data/raw
BRONZE_PATH=/opt/data/lake/bronze
SILVER_PATH=/opt/data/lake/silver
GOLD_PATH=/opt/data/lake/gold

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# AWS (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=ipl-data-lakehouse
